{
  "name": "@familyctx/expo",
  "version": "0.1.0",
  "description": "Expo bindings for FamilyContext.",
  "homepage": "https://github.com/familyctx/expo#readme",
  "bugs": {
    "url": "https://github.com/familyctx/expo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/familyctx/expo.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "Preston Arnold <prestonarnold.uk>",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@familyctx/react": "^0.1.0"
  },
  "peerDependencies": {
    "@familyctx/core": "^0.1.0",
    "expo-secure-store": ">=14",
    "react": ">=18"
  }
}
